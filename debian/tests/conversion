compare_files() {
  local label="$1"
  local expected="$2"
  local actual="$3"

  python3 - "$label" "$expected" "$actual" <<'PY'
import difflib
import pathlib
import sys

label, expected_path, actual_path = sys.argv[1:]
expected = pathlib.Path(expected_path).read_text(encoding="utf-8")
actual = pathlib.Path(actual_path).read_text(encoding="utf-8")

if expected.endswith("\n"):
    expected = expected[:-1]
if actual.endswith("\n"):
    actual = actual[:-1]

if expected != actual:
    diff = "".join(
        difflib.unified_diff(
            [line + "\n" for line in expected.splitlines()],
            [line + "\n" for line in actual.splitlines()],
            fromfile=expected_path,
            tofile=actual_path,
        )
    )
    sys.stderr.write(f"Fixture mismatch for {label}\n{diff}")
    raise SystemExit(1)
PY
}

run_fixture() {
  local label="$1"
  local expected="$2"
  local input="$3"
  shift 3

  local output="$TMPDIR/${label//\//_}.out"
  "$@" < "$input" > "$output"
  compare_files "$label" "$expected" "$output"
}

